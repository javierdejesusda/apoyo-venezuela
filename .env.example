# All variables are OPTIONAL. With none set, the app runs in demo mode
# (an in-memory store with sample data, nothing shared between users).
# Copy this file to .env.local and fill in the values you need.

# Supabase - set BOTH to use live, shared data instead of demo mode.
# The anon key is public by design (it ships in the browser bundle).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox - enables address autocomplete and reverse geocoding in the report form.
# Server-only on purpose (no NEXT_PUBLIC_ prefix), so it never ships in the browser
# bundle. Restrict it by URL in the Mapbox dashboard.
MAPBOX_TOKEN=

# Canonical site URL, used for absolute links and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Web Analytics beacon token.
NEXT_PUBLIC_CF_BEACON_TOKEN=
